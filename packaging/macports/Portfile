# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4

PortSystem          1.0
PortGroup           golang 1.0

go.setup            gorodulin/prj 0.3.0 v
categories          devel
license             Apache-2
maintainers         {gorodulin @gorodulin}
description         Projector: project folder, metadata, and link manager
long_description    Projector (prj) is a cross-platform CLI tool for managing \
                    project folders, their metadata, and links. Organizes \
                    projects by topic using a tag-driven link tree.

checksums           rmd160  6007919fb104310ccca9ff5e5e6dc51fb9171846 \
                    sha256  fd60322a643dedfc2365045218958c84ee76ce548d3c6aea8ae3ba3e2393ca52 \
                    size    44759

build.args-append   -ldflags "-s -w -X github.com/gorodulin/prj/cmd.version=${version}"

destroot {
    xinstall -m 0755 ${worksrcpath}/prj ${destroot}${prefix}/bin/

    # Shell completions
    xinstall -d ${destroot}${prefix}/share/bash-completion/completions
    xinstall -d ${destroot}${prefix}/share/zsh/site-functions
    xinstall -d ${destroot}${prefix}/share/fish/vendor_completions.d
    system "${destroot}${prefix}/bin/prj completion bash > ${destroot}${prefix}/share/bash-completion/completions/prj"
    system "${destroot}${prefix}/bin/prj completion zsh > ${destroot}${prefix}/share/zsh/site-functions/_prj"
    system "${destroot}${prefix}/bin/prj completion fish > ${destroot}${prefix}/share/fish/vendor_completions.d/prj.fish"
}

notes "
Create a config file to get started:

    mkdir -p ~/Library/Application\\ Support/prj
    echo '{ \"projects_folder\": \"/path/to/your/projects\" }' > \\
      ~/Library/Application\\ Support/prj/config.json

See \`prj --help\` for available commands.
"
